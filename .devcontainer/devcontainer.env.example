# Template for Garmin SDK credentials.
# Copy this file to "devcontainer.env" (same folder) and fill in your values.
# The real devcontainer.env is gitignored — it contains your password in plaintext.
#
#   cp .devcontainer/devcontainer.env.example .devcontainer/devcontainer.env
#
# Format: KEY=VALUE per line, no quotes, no "export".

# Your Garmin account e-mail (same as Garmin Connect)
GARMIN_USERNAME=your@email.com

# Your Garmin account password
GARMIN_PASSWORD=your-password

# Agreement acceptance hash — current value already filled in below.
# Re-check with: ./bin/connect-iq-sdk-manager agreement view
CIQ_AGREEMENT_HASH=CC737BBBA104D7740D5BBCF27D0F6382

# Optional: pin a specific SDK version, e.g. 6.4.2
# Leave commented to install the latest SDK >= 6.2.2.
#CIQ_SDK_VERSION=6.4.2
